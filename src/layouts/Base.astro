---
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Plausible from "../components/Plausible.astro";

type Props = {
	title?: string;
	description?: string;
	image?: ImageMetadata;
	bodyClass?: string;
};

const { title, description, image, bodyClass } = Astro.props;
const bodyClasses = ["flex", "items-center", bodyClass].filter(Boolean).join(" ");
---

<html lang="en">
	<head>
		<BaseHead
			title={title ?? "Technodruid"}
			description={description ?? "A blog about technology and druidry"}
			image={image}
		/>
		<Plausible />
	</head>
	<body class={bodyClasses}>
		<Header />
		<main class="flex
		items-center
		p-4
		md:p-8">
			<div class="w-full flex flex-col items-center">
				<slot />
			</div>

			<Footer />
		</main>
	</body>
</html>
