---
import type { HTMLAttributes } from "astro/types";
import NavBar from "./NavBar.astro";

type Props = HTMLAttributes<"header">;

const { ...props } = Astro.props;
---

<header class:list={["m-auto pb-4", props.class]} {...props}>
	<nav>
		<h2 class="mt-0 mb-8 md:mb-10 flex justify-center md:justify-start">
			<a
				href="/"
				aria-label="Technodruid home"
				class="logo-link no-underline"
			>
				<span class="logo tracking-wide font-medium text-2xl md:text-4xl lg:text-5xl">
					<span class="logo-chevron" aria-hidden="true">❯</span>
					<span class="logo-name">technodruid</span>
					<span class="logo-cursor" aria-hidden="true"></span>
				</span>
			</a>
		</h2>
	</nav>
	<NavBar />
	<div class="social-links"></div>
</header>

<style>
	.logo-chevron {
		opacity: 0.55;
		margin-inline-end: 0.2em;
	}

	.logo-cursor::after {
		content: "▌";
		display: inline-block;
		margin-inline-start: 0.1em;
		animation: logo-blink 1.1s steps(2, start) infinite;
	}

	@keyframes logo-blink {
		to {
			opacity: 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.logo-cursor::after {
			animation: none;
		}
	}
</style>
