---
import HeaderLink from "./HeaderLink.astro";

interface NavEntry {
	href: string;
	label: string;
}

const entries: NavEntry[] = [
	{ href: "/", label: "CREED" },
	{ href: "/codex", label: "CODEX" },
	{ href: "/practices", label: "PRACTICES" },
	{ href: "/circuits", label: "CIRCUITS" },
	{ href: "/library", label: "LIBRARY" },
	{ href: "/about", label: "ABOUT" },
];
---

<div
	class:list={[
		"internal-links w-full lg:max-w-3xl lg:mx-auto grid grid-cols-2 lg:flex flex-wrap lg:justify-between text-lg lg:text-base gap-x-16 px-6 lg:px-0",
	]}
>
	{entries.map((entry) => <HeaderLink href={entry.href}>{entry.label}</HeaderLink>)}
</div>
