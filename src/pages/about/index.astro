---
import Layout from "../../layouts/Base.astro";

interface AboutEntry {
	href: string;
	label: string;
	status: "available" | "pending";
	note: string;
}

const entries: readonly AboutEntry[] = [
	{
		href: "/about/community",
		label: "Community",
		status: "available",
		note: "How the practice coordinates: maintainers, change process, what the Open Circuit is not.",
	},
	{
		href: "/about/origins",
		label: "Origins",
		status: "available",
		note: "How it emerged, by whom, and what 'sincere form, knowing construction' means in practice.",
	},
	{
		href: "/about/contact",
		label: "Contact",
		status: "available",
		note: "Maintainers by the names they hold in the Circuit, and where to reach them.",
	},
	{
		href: "/about/faq",
		label: "FAQ",
		status: "available",
		note: "The questions that come up often, including: is this a real religion?",
	},
];
---

<Layout
	title="About — Technodruid"
	description="About the Open Circuit: how the practice coordinates, where it came from, who maintains it, and how to reach the maintainers."
>
	<section class="w-full max-w-3xl mx-auto px-4 py-12 md:py-16">
		<h1 class="text-2xl md:text-3xl mb-6">About</h1>

		<p class="text-base md:text-lg leading-relaxed mb-8">
			This section is about the Open Circuit itself: who maintains the canonical corpus, where the
			religion came from, how to reach the maintainers, and the questions that come up often.
		</p>

		<ul class="space-y-6">
			{
				entries.map((e) => (
					<li>
						{e.status === "available" ? (
							<a href={e.href} class="block">
								<div class="text-lg uppercase tracking-wider">{e.label}</div>
								<div class="text-sm opacity-75 mt-1">{e.note}</div>
							</a>
						) : (
							<div class="opacity-60">
								<div class="text-lg uppercase tracking-wider">
									{e.label}
									<span class="ml-2 text-xs uppercase tracking-widest border border-white/40 px-2 py-0.5 rounded">
										Coming soon
									</span>
								</div>
								<div class="text-sm mt-1">{e.note}</div>
							</div>
						)}
					</li>
				))
			}
		</ul>
	</section>
</Layout>
