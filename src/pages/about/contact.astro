---
import { getEntry, render } from "astro:content";
import LivingDoc from "../../layouts/LivingDoc.astro";

const contact = await getEntry("living", "about-contact");
if (!contact) {
	throw new Error("Required living entry 'about-contact' not found in src/content/living/.");
}
const { Content } = await render(contact);
---

<LivingDoc entry={contact}>
	<Content />
</LivingDoc>
