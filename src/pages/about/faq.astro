---
import { getEntry, render } from "astro:content";
import LivingDoc from "../../layouts/LivingDoc.astro";

const faq = await getEntry("living", "about-faq");
if (!faq) {
	throw new Error(
		"Required living entry 'about-faq' not found in src/content/living/.",
	);
}
const { Content } = await render(faq);
---

<LivingDoc entry={faq}>
	<Content />
</LivingDoc>
