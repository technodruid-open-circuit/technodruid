---
import { getEntry, render } from "astro:content";
import LivingDoc from "../../layouts/LivingDoc.astro";

const links = await getEntry("living", "library-links");
if (!links) {
	throw new Error(
		"Required living entry 'library-links' not found in src/content/living/.",
	);
}
const { Content } = await render(links);
---

<LivingDoc entry={links}>
	<Content />
</LivingDoc>
