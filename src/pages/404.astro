---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Base.astro";

const creed = await getEntry("canonical", "creed");
if (!creed) {
	throw new Error("Required canonical entry 'creed' not found in src/content/canonical/.");
}
const { Content } = await render(creed);
---

<Layout
	title="Not found — Technodruid"
	description="The page you sought is not here. The Creed is below; walk on to another part of the site."
>
	<section
		class="not-found-page w-full max-w-6xl mx-auto px-4 py-12 md:py-20 text-center"
		aria-labelledby="not-found-heading"
	>
		<h1 id="not-found-heading" class="text-2xl md:text-3xl tracking-wider uppercase">
			Page not found
		</h1>

		<p class="prose mt-6 text-base md:text-lg opacity-80">
			No page lives at this path. Below is what we believe; may it point you somewhere better.
		</p>

		<div
			class="creed mt-12 md:mt-16 text-base md:text-lg lg:text-xl leading-relaxed space-y-5 md:space-y-6"
		>
			<Content />
		</div>

		<div
			class="not-found-rule mt-20 md:mt-28 flex justify-center items-center gap-3 opacity-40 text-xs"
			aria-hidden="true"
		>
			<span>░▒▓</span>
			<span>·</span>
			<span>▓▒░</span>
		</div>

		<nav class="mt-8 md:mt-10 flex justify-center" aria-label="Try another page">
			<a
				id="random-page-link"
				href="/codex"
				class="inline-block min-w-[14rem] border border-white px-6 py-3 uppercase tracking-wider hover:bg-white hover:text-black"
			>
				Try another page
			</a>
		</nav>
	</section>
</Layout>

<script>
	const ROUTES = [
		"/codex",
		"/practices/rite",
		"/about/community",
		"/about/origins",
		"/about/contact",
	] as const;
	const link = document.getElementById("random-page-link");
	if (link instanceof HTMLAnchorElement) {
		const idx = Math.floor(Math.random() * ROUTES.length);
		link.href = ROUTES[idx];
	}
</script>
