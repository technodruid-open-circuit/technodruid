---
import { getEntry, render } from "astro:content";
import CanonicalDoc from "../../layouts/CanonicalDoc.astro";

const charter = await getEntry("canonical", "circuits-charter");
if (!charter) {
	throw new Error("Required canonical entry 'circuits-charter' not found in src/content/canonical/.");
}
const { Content, headings } = await render(charter);
---

<CanonicalDoc entry={charter} headings={headings}>
	<Content />
</CanonicalDoc>
