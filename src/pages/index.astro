---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Base.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE, SOURCE_REPO_URL } from "../consts";

const creed = await getEntry("canonical", "creed");
if (!creed) {
	throw new Error("Required canonical entry 'creed' not found in src/content/canonical/.");
}
const { Content } = await render(creed);
const { version, amendedAt } = creed.data;
const sourcePath = (creed.filePath ?? `src/content/canonical/${creed.id}.md`).replace(/^\.\//, "");
const sourceUrl = `${SOURCE_REPO_URL}/blob/main/${sourcePath}`;
const historyUrl = `${SOURCE_REPO_URL}/commits/main/${sourcePath}`;

interface Cta {
	href: string;
	label: string;
}

const ctas: readonly Cta[] = [
	{ href: "/codex", label: "Read the Codex" },
	// { href: "/circuits/directory", label: "Find a Circuit" },
	{ href: "/practices", label: "Begin Practice" },
];
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section
		class="creed-page w-full max-w-6xl mx-auto px-4 py-12 md:py-20 text-center"
		aria-labelledby="creed-heading"
	>
		<h1 id="creed-heading" class="sr-only">The Creed</h1>

		<div class="creed text-base md:text-lg lg:text-xl leading-relaxed space-y-5 md:space-y-6">
			<Content />
		</div>

		<div
			class="creed-rule mt-20 md:mt-28 flex justify-center items-center gap-3 opacity-40 text-xs"
			aria-hidden="true"
		>
			<span>░▒▓</span>
			<span>·</span>
			<span>▓▒░</span>
		</div>

		<nav
			class="mt-8 md:mt-10 flex flex-col items-center md:flex-row md:justify-center gap-4 md:gap-6"
			aria-label="Primary calls to action"
		>
			{
				ctas.map((cta) => (
					<a
						href={cta.href}
						class="inline-block min-w-[14rem] border border-white px-6 py-3 uppercase tracking-wider hover:bg-white hover:text-black"
					>
						{cta.label}
					</a>
				))
			}
		</nav>

		<footer class="creed-meta mt-24 md:mt-32 text-xs opacity-60">
			<hr class="mx-auto w-24 border-white/30" aria-hidden="true" />
			<p class="mt-4 flex flex-wrap justify-center items-baseline gap-x-3 gap-y-1">
				<span>Version <span class="font-medium" data-version={version}>{version}</span></span>
				<span class="opacity-60" aria-hidden="true">·</span>
				<span>Amended <FormattedDate date={amendedAt} /></span>
			</p>
			<p class="mt-2 flex justify-center gap-x-3">
				<a href={sourceUrl}>Source</a>
				<span class="opacity-60" aria-hidden="true">·</span>
				<a href={historyUrl}>Revision history</a>
			</p>
		</footer>
	</section>
</Layout>
